{
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/bot.ts",
    "build": "tsup",
    "start": "node dist/bot.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "name": "carrotbot",
  "version": "1.0.0",
  "main": "dist/bot.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joelkaret/CarrotBotJS.git"
  },
  "bin": {
    "carrotbot": "./dist/bot.js"
  },
  "keywords": [],
  "author": "Joel Karet",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/joelkaret/CarrotBotJS/issues"
  },
  "homepage": "https://github.com/joelkaret/CarrotBotJS#readme",
  "dependencies": {
    "@discord-player/extractor": "^4.2.1",
    "@discordjs/builders": "^1.4.0",
    "@discordjs/rest": "^1.7.1",
    "axios": "^1.2.1",
    "colorette": "^2.0.20",
    "discord-api-types": "^0.37.42",
    "discord.js": "^14.11.0",
    "dotenv": "^16.0.3",
    "mongodb": "^5.2.0",
    "mongoose": "^7.0.3",
    "node-schedule": "^2.1.1",
    "python": "^0.0.4",
    "toad-scheduler": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/node-schedule": "^2.1.5",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.6",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.4",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "description": ""
